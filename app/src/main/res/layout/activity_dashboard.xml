<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Dashboard">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/light_blue"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/appLogo_top"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:srcCompat="@drawable/pocketpallogo" />

        <TextView
            android:id="@+id/tv_topofdashboard"
            android:layout_width="wrap_content"
            android:layout_height="51dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Dashboard"
            android:textSize="30dp" />
    </LinearLayout>


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/light_blue"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/appLogo_bottom"
            android:layout_width="30dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            app:srcCompat="@drawable/pocketpallogo" />
    </LinearLayout>

    <TextView
        android:id="@+id/balance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="124dp"
        android:text="Total Balance:"
        android:textSize="25dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_totalbalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="148dp"
        android:text=""
        android:textSize="25dp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/balance"
        app:layout_constraintTop_toTopOf="@+id/balance" />

    <Button
        android:id="@+id/button_addexpenses"
        android:layout_width="177dp"
        android:layout_height="84dp"
        android:layout_marginStart="116dp"
        android:layout_marginTop="324dp"
        android:backgroundTint="@android:color/holo_blue_light"
        android:text="Add Expenses"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/button_viewexpenses"
        android:layout_width="177dp"
        android:layout_height="84dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@android:color/holo_blue_light"
        android:text="View Expenses"
        app:layout_constraintStart_toStartOf="@+id/button_addexpenses"
        app:layout_constraintTop_toBottomOf="@+id/button_addexpenses" />

    <Button
        android:id="@+id/button_viewwishlist"
        android:layout_width="177dp"
        android:layout_height="84dp"
        android:text="View Wishlist"
        android:backgroundTint="@android:color/holo_blue_light"
        app:layout_constraintStart_toStartOf="@+id/button_viewexpenses"
        app:layout_constraintTop_toBottomOf="@+id/button_viewexpenses" />


</androidx.constraintlayout.widget.ConstraintLayout>